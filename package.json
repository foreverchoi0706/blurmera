    "react-native-worklets-core": "^1.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.3.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",

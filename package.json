{
  "name": "blurema",
  "main": "expo-router/entry",
  "version": "26.5.21",
  "engines": {
    "node": "22.22.2"
  },
  "scripts": {
    "postinstall": "patch-package",
    "prepare": "husky install",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "format": "prettier --write .",
    "pod-install": "cd ios && pod install",
    "expo-export:web": "npx expo export --platform web",
    "expo-fix": "npx expo install --fix",
    "expo-prebuild": "npx expo prebuild",
    "eas-deploy-prod:web": "npx eas-cli deploy --prod",
    "eas-build:android": "npx eas-cli build --platform android --profile production",
    "eas-update:android": "npx eas update --platform android",
    "eas-submit:android": "npx eas submit --platform android"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.34",
